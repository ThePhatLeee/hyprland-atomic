# Prefer modern completion behavior
autoload -Uz compinit
compinit

# History behavior
HISTSIZE=10000
SAVEHIST=10000
HISTFILE="$HOME/.zsh_history"
setopt APPEND_HISTORY
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY

# Directory and navigation quality-of-life
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt INTERACTIVE_COMMENTS

# Better shell UX
setopt EXTENDED_GLOB
setopt NO_BEEP

# Completion styling
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Useful defaults for included tools
if command -v eza >/dev/null 2>&1; then
  alias ls='eza --group-directories-first'
  alias ll='eza -lah --group-directories-first'
  alias la='eza -a --group-directories-first'
fi

if command -v bat >/dev/null 2>&1; then
  alias cat='bat --paging=never'
fi

if command -v fzf >/dev/null 2>&1; then
  if command -v fd >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
  elif command -v fdfind >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git'
  elif command -v rg >/dev/null 2>&1; then
    export FZF_DEFAULT_COMMAND='rg --files --hidden --follow -g "!.git"'
  fi

  fzf_completion_loaded=0
  fzf_key_bindings_loaded=0
  for fzf_base in /usr/share/fzf /usr/local/share/fzf "$HOME/.fzf"; do
    if [ "${fzf_completion_loaded}" -eq 0 ] && [ -f "${fzf_base}/shell/completion.zsh" ]; then
      source "${fzf_base}/shell/completion.zsh"
      fzf_completion_loaded=1
    fi
    if [ "${fzf_key_bindings_loaded}" -eq 0 ] && [ -f "${fzf_base}/shell/key-bindings.zsh" ]; then
      source "${fzf_base}/shell/key-bindings.zsh"
      fzf_key_bindings_loaded=1
    fi
    if [ "${fzf_completion_loaded}" -eq 1 ] && [ "${fzf_key_bindings_loaded}" -eq 1 ]; then
      break
    fi
  done
  unset fzf_completion_loaded fzf_key_bindings_loaded fzf_base
fi

if command -v fdfind >/dev/null 2>&1 && ! command -v fd >/dev/null 2>&1; then
  alias fd='fdfind'
fi

if command -v gh >/dev/null 2>&1; then
  eval "$(gh completion --shell zsh)"
fi

# zoxide (if present)
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# Starship prompt
export STARSHIP_CONFIG="$HOME/.config/starship.toml"
if command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
fi
